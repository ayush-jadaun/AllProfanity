{
  "$schema": "./config.schema.json",
  "algorithm": {
    "matching": "hybrid",
    "useAhoCorasick": true,
    "useBloomFilter": true,
    "useContextAnalysis": true
  },
  "ahoCorasick": {
    "enabled": true,
    "prebuild": true
  },
  "bloomFilter": {
    "enabled": true,
    "expectedItems": 10000,
    "falsePositiveRate": 0.01
  },
  "contextAnalysis": {
    "enabled": true,
    "contextWindow": 100,
    "languages": ["en"],
    "scoreThreshold": 0.55
  },
  "profanityDetection": {
    "enableLeetSpeak": true,
    "caseSensitive": false,
    "strictMode": true,
    "detectPartialWords": false,
    "defaultPlaceholder": "*"
  },
  "evasionProtection": {
    "unicode": true,
    "repeatedCharacters": false,
    "maskedCharacters": false,
    "separatedLetters": false
  },
  "performance": {
    "enableCaching": true,
    "cacheSize": 2000
  },
  "silent": true
}
